#!/bin/bash
# Installs a pinned, checksum-verified Syft onto PATH for the build.
# This hook is SOURCED: it must fall through on success (no `exit 0`) so the
# exported PATH survives, and only `exit 1` on hard failure. Because it is
# sourced, it snapshots the shell options and EXIT trap up front and restores
# them on the success path so `set -euo pipefail` and the cleanup trap do not
# leak into (or clobber) the agent's bootstrap shell. The `exit 1` hard-failure
# paths intentionally abort the bootstrap, so they skip the restore.

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/shared.bash
source "${HOOK_DIR}/../lib/shared.bash"

SYFT_DEFAULT_PIN="v1.46.0@sha256:2fefc202b2eccab83888cc91f5a364a75df0dd777afbbae5b5e23ebd93d81ac6"

__dd_oldopts="$(set +o)"
__dd_oldtrap="$(trap -p EXIT)"
set -euo pipefail

pin="$(plugin_read SYFT_VERSION "${SYFT_DEFAULT_PIN}")"
if ! parse_syft_pin "${pin}"; then
  echo ":docker: docker-diff: invalid syft-version '${pin}' (expected <version>@sha256:<64-hex>)" >&2
  exit 1
fi
SYFT_VERSION="${SYFT_PIN_VERSION}"

os="$(uname -s | tr '[:upper:]' '[:lower:]')"
arch="$(uname -m)"
case "$arch" in
  x86_64 | amd64) arch="amd64" ;;
  aarch64 | arm64) arch="arm64" ;;
  *)
    echo ":docker: docker-diff: unsupported architecture: ${arch}" >&2
    exit 1
    ;;
esac

version_no_v="${SYFT_VERSION#v}"
tag="v${version_no_v}"
asset="syft_${version_no_v}_${os}_${arch}.tar.gz"
checksums="syft_${version_no_v}_checksums.txt"
base_url="https://github.com/anchore/syft/releases/download/${tag}"

workdir="$(mktemp -d)"
trap 'rm -rf "${workdir}"' EXIT

dl() {
  curl --proto '=https' --tlsv1.2 -fsSL "$1" -o "$2"
}

echo ":docker: docker-diff: installing syft ${tag} for ${os}/${arch}" >&2

if ! dl "${base_url}/${asset}" "${workdir}/${asset}"; then
  echo "docker-diff: failed to download ${asset}" >&2
  exit 1
fi
if ! dl "${base_url}/${checksums}" "${workdir}/${checksums}"; then
  echo "docker-diff: failed to download ${checksums}" >&2
  exit 1
fi


manifest_actual="$(sha256_file "${workdir}/${checksums}")"
if [ "${SYFT_PIN_SHA256}" != "${manifest_actual}" ]; then
  echo "docker-diff: syft checksums.txt does not match the pinned sha256" >&2
  echo "  pinned: ${SYFT_PIN_SHA256}" >&2
  echo "  actual: ${manifest_actual}" >&2
  exit 1
fi

expected="$(awk -v f="${asset}" '$2 == f {print $1}' "${workdir}/${checksums}")"
if [ -z "${expected}" ]; then
  echo "docker-diff: no checksum entry for ${asset}" >&2
  exit 1
fi
actual="$(sha256_file "${workdir}/${asset}")"
if [ "${expected}" != "${actual}" ]; then
  echo "docker-diff: checksum mismatch for ${asset}" >&2
  echo "  expected: ${expected}" >&2
  echo "  actual:   ${actual}" >&2
  exit 1
fi

install_dir="$(mktemp -d)"
tar -xzf "${workdir}/${asset}" -C "${workdir}" syft
install -m 0755 "${workdir}/syft" "${install_dir}/syft"

# Success: clean up our workdir, then restore the sourcing shell's options and
# EXIT trap before falling through so nothing leaks into the bootstrap.
rm -rf "${workdir}"
trap - EXIT
[ -n "${__dd_oldtrap}" ] && eval "${__dd_oldtrap}"
eval "${__dd_oldopts}"
unset __dd_oldopts __dd_oldtrap

export PATH="${install_dir}:${PATH}"
echo "docker-diff: syft ready (${install_dir}/syft)" >&2

# Sourced hook: drop our working vars and helper functions so generic names
# (os/arch/workdir/...) and lib/shared.bash's functions do not leak into (or
# clobber a later plugin's use of) the agent's bootstrap shell.
unset os arch version_no_v tag asset checksums base_url workdir \
      expected actual SYFT_VERSION HOOK_DIR PLUGIN_PREFIX install_dir \
      pin manifest_actual SYFT_PIN_VERSION SYFT_PIN_SHA256 SYFT_DEFAULT_PIN
unset -f dl plugin_read read_list_property image_repo_tag image_repo \
         short_digest version_gt sha256_file repo_slug is_node_version \
         parse_syft_pin
