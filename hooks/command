#!/bin/bash
# Post a per-image SBOM diff (and Node.js changelogs when the runtime moved) into
# the PR description for a Renovate Docker-digest bump.
set -euo pipefail

HOOK_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/shared.bash
source "${HOOK_DIR}/../lib/shared.bash"

MAX_RELEASES=20
MARKER_START="<!-- docker-diff:start -->"
MARKER_END="<!-- docker-diff:end -->"
DIST_INDEX_URL="https://nodejs.org/dist/index.json"
CHANGELOG_URL_BASE="https://raw.githubusercontent.com/nodejs/node/main/doc/changelogs"

WORKDIR="$(mktemp -d)"
trap 'rm -rf "${WORKDIR}"' EXIT

log() { echo "docker-diff: $*" >&2; }

scan_packages() {
  local ref="$1" out="$2"
  # On scan failure write an empty file (so the file still exists for callers) and
  # return non-zero, so the caller can distinguish "scan failed" from "no packages".
  if ! syft scan "registry:${ref}" -q -o syft-json 2>/dev/null \
       | jq -r '.artifacts[] | [.type, .name, .version] | @tsv' \
       | sort -u >"$out"; then
    : >"$out"
    return 1
  fi
}

node_version_from() {
  awk -F'\t' '
    $2 == "node" { if ($1 == "binary") b = $3; else if (g == "") g = $3 }
    END { print (b != "" ? b : g) }
  ' "$1"
}

diff_packages() {
  # awk emits a "name<TAB>bullet" key column; sort by name, then drop the key.
  awk -F'\t' '
    function pkg_url(type, name, ver) {
      if (name == "node")  return "https://nodejs.org/en/blog/release/v" ver
      if (type == "npm")   return "https://www.npmjs.com/package/" name "/v/" ver
      if (type == "deb")   return "https://packages.debian.org/" name
      if (type == "apk")   return "https://pkgs.alpinelinux.org/packages?name=" name
      return ""
    }
    function lnk(type, name, ver,   u) {
      u = pkg_url(type, name, ver)
      return u == "" ? "`" name "`" : "[`" name "`](" u ")"
    }
    FNR == NR { ov[$1 FS $2] = $3; onm[$1 FS $2] = $2; otype[$1 FS $2] = $1; next }
    {
      k = $1 FS $2; seen[k] = 1
      if (!(k in ov))       printf "%s\t- %s added (`%s`)\n", $2, lnk($1, $2, $3), $3
      else if (ov[k] != $3) printf "%s\t- %s: `%s` → `%s`\n", $2, lnk($1, $2, $3), ov[k], $3
    }
    END {
      for (k in ov) if (!(k in seen))
        printf "%s\t- %s removed (`%s`)\n", onm[k], lnk(otype[k], onm[k], ov[k]), ov[k]
    }
  ' "$1" "$2" | sort -f | cut -f2-
}

fetch_dist_index() {
  if [ ! -f "${WORKDIR}/index.json" ]; then
    curl --proto '=https' --tlsv1.2 -fsSL "${DIST_INDEX_URL}" \
      -o "${WORKDIR}/index.json" 2>/dev/null || return 1
  fi
}

# Range is half-open (before, after]: excludes the current version, includes the target.
releases_between() {
  local before="$1"
  local after="$2"
  fetch_dist_index || return 0

  local out=()
  local v
  while IFS= read -r v; do
    [ -z "$v" ] && continue
    if version_gt "$v" "$before" && { [ "$v" = "$after" ] || version_gt "$after" "$v"; }; then
      out+=("$v")
    fi
  done < <(jq -r '.[].version | ltrimstr("v")' "${WORKDIR}/index.json")

  [ ${#out[@]} -eq 0 ] && return 0
  printf '%s\n' "${out[@]}" | sort -rV | head -n "${MAX_RELEASES}"
}

changelog_section() {
  local version="$1"
  local major="${version%%.*}"
  local file="${WORKDIR}/CHANGELOG_V${major}.md"

  if [ ! -f "$file" ]; then
    curl --proto '=https' --tlsv1.2 -fsSL "${CHANGELOG_URL_BASE}/CHANGELOG_V${major}.md" \
      -o "$file" 2>/dev/null || : >"$file"
  fi

  awk -v id="$version" '
    BEGIN { tag = "<a id=\"" id "\"" }
    index($0, tag) { cap = 1; found = 1; print; next }
    cap && index($0, "<a id=\"") { cap = 0 }
    cap { print }
    END { if (!found) printf "See https://github.com/nodejs/node/releases/tag/v%s", id }
  ' "$file"
}

# Only the Renovate branch(es) carry the digest bumps; skip everything else.
# (read_list_property fills the global `result`; see lib/shared.bash.)
branch_allowed() {
  local branch="${BUILDKITE_BRANCH:-}"
  if [ -z "$branch" ]; then
    branch="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || true)"
  fi

  if ! read_list_property BRANCHES; then
    result=("renovate-docker-images")
  fi

  local b
  for b in "${result[@]}"; do
    [ "$b" = "$branch" ] && return 0
  done
  log "branch '${branch}' not in allow-list; skipping"
  return 1
}

# A fork PR's diff is attacker-controlled (the images we pull, the versions we
# render), so callers refuse to scan it. The branch allow-list is not a trust
# boundary: a fork can name its branch anything. Push builds are trusted.
is_fork_pr() {
  local pr="${BUILDKITE_PULL_REQUEST:-}"
  case "$pr" in
    '' | *[!0-9]*) return 1 ;; # not a PR build -> trusted internal build
  esac
  local src_repo="${BUILDKITE_PULL_REQUEST_REPO:-}"
  local base_repo="${BUILDKITE_REPO:-}"
  [ -n "$src_repo" ] && [ -n "$base_repo" ] \
    && [ "$(repo_slug "$src_repo")" != "$(repo_slug "$base_repo")" ]
}

resolve_diff_base() {
  local base="${BUILDKITE_PIPELINE_DEFAULT_BRANCH:-main}"
  if git rev-parse --verify -q "origin/${base}" >/dev/null; then
    printf 'origin/%s' "$base"
  elif git rev-parse --verify -q "${base}" >/dev/null; then
    printf '%s' "$base"
  else
    printf 'HEAD~1'
  fi
}

extract_refs() {
  local diff="$1" removed="$2" added="$3"
  local regex='[A-Za-z0-9][A-Za-z0-9._/:-]*@sha256:[0-9a-fA-F]{64}'
  # Skip the BuildKit frontend pin (`# syntax=docker/dockerfile:...`): it is a
  # build frontend, not a runtime image worth SBOM-diffing. Any diff line that
  # contains `syntax=` is dropped before refs are extracted.
  printf '%s\n' "$diff" | grep '^-' | grep -v 'syntax=' | grep -oE "$regex" >"$removed" || :
  printf '%s\n' "$diff" | grep '^+' | grep -v 'syntax=' | grep -oE "$regex" >"$added" || :
}

# image_repo_family lives in lib/shared.bash (sourced above).

# Greedy two-pass match: pair by repo:tag first, then by repo only, so a digest
# bump still matches when the tag changed in the same update. Emits "before<TAB>after".
pair_digests() {
  local rem=() add=() line
  while IFS= read -r line; do [ -n "$line" ] && rem+=("$line"); done <"$1"
  while IFS= read -r line; do [ -n "$line" ] && add+=("$line"); done <"$2"

  local keyfn i j key_r
  for keyfn in image_repo_tag image_repo; do
    for ((i = 0; i < ${#rem[@]}; i++)); do
      [ -z "${rem[i]}" ] && continue
      key_r="$("$keyfn" "${rem[i]}")"
      for ((j = 0; j < ${#add[@]}; j++)); do
        [ -z "${add[j]}" ] && continue
        if [ "$key_r" = "$("$keyfn" "${add[j]}")" ]; then
          printf '%s\t%s\n' "${rem[i]}" "${add[j]}"
          rem[i]=""
          add[j]=""
          break
        fi
      done
    done
  done

  # Third pass: version-normalized "family" match, so a Node major bump that
  # renames the repository (node-22-alpine -> node-24-alpine) still pairs.
  # Guarded: only pair when the family key is unambiguous among the leftovers
  # (exactly one unpaired removed and one unpaired added share it), so we never
  # collapse two genuinely different images.
  local cnt_r cnt_a m
  for ((i = 0; i < ${#rem[@]}; i++)); do
    [ -z "${rem[i]}" ] && continue
    key_r="$(image_repo_family "${rem[i]}")"
    cnt_r=0
    for ((m = 0; m < ${#rem[@]}; m++)); do
      [ -n "${rem[m]}" ] && [ "$(image_repo_family "${rem[m]}")" = "$key_r" ] && cnt_r=$((cnt_r + 1))
    done
    cnt_a=0
    for ((j = 0; j < ${#add[@]}; j++)); do
      [ -n "${add[j]}" ] && [ "$(image_repo_family "${add[j]}")" = "$key_r" ] && cnt_a=$((cnt_a + 1))
    done
    [ "$cnt_r" -eq 1 ] && [ "$cnt_a" -eq 1 ] || continue
    for ((j = 0; j < ${#add[@]}; j++)); do
      [ -z "${add[j]}" ] && continue
      if [ "$(image_repo_family "${add[j]}")" = "$key_r" ]; then
        printf '%s\t%s\n' "${rem[i]}" "${add[j]}"
        rem[i]=""
        add[j]=""
        break
      fi
    done
  done
}

render_pkgdiff() {
  local pkgdiff="$1" n
  if [ -z "$pkgdiff" ]; then
    printf '_No package changes detected._\n\n'
    return
  fi
  n="$(printf '%s\n' "$pkgdiff" | wc -l | tr -d ' ')"
  printf '<details><summary>%s package change(s)</summary>\n\n' "$n"
  printf '%s\n\n' "$pkgdiff"
  printf '</details>\n\n'
}

render_changelogs() {
  local bver="$1" aver="$2" releases v sec
  releases="$(releases_between "$bver" "$aver")"
  if [ -z "$releases" ]; then
    log "no in-range Node.js releases for ${bver} -> ${aver}"
    return
  fi
  printf '#### Node.js changelog\n\n'
  while IFS= read -r v; do
    [ -z "$v" ] && continue
    sec="$(changelog_section "$v")"
    printf '<details><summary>v%s</summary>\n\n%s\n\n</details>\n\n' "$v" "$sec"
  done <<<"$releases"
}

# Returns success when the Node.js runtime version changed, so the caller can count it.
process_pair() {
  local bref="$1" aref="$2"
  local repo bshort ashort oldpkgs newpkgs bver aver pkgdiff node_changed=1
  repo="$(image_repo "$aref")"
  bshort="$(short_digest "$bref")"
  ashort="$(short_digest "$aref")"
  log "checking ${repo} (${bshort} -> ${ashort})"

  oldpkgs="$(mktemp "${WORKDIR}/old.XXXXXX")"
  newpkgs="$(mktemp "${WORKDIR}/new.XXXXXX")"
  local scan_ok=1
  scan_packages "$bref" "$oldpkgs" || scan_ok=0
  scan_packages "$aref" "$newpkgs" || scan_ok=0

  bver="$(node_version_from "$oldpkgs")"
  aver="$(node_version_from "$newpkgs")"
  if [ -n "$bver" ] && [ -n "$aver" ] \
     && is_node_version "$bver" && is_node_version "$aver" \
     && [ "$bver" != "$aver" ]; then
    node_changed=0
  fi

  pkgdiff="$(diff_packages "$oldpkgs" "$newpkgs")"

  # shellcheck disable=SC2016 # backticks are literal markdown, not command substitution
  printf '### %s (`%s` → `%s`)\n\n' "$repo" "$bshort" "$ashort"
  if [ "$node_changed" = 0 ]; then
    # shellcheck disable=SC2016
    printf 'Node.js `%s` → `%s`\n\n' "$bver" "$aver"
  fi
  if [ "$scan_ok" -eq 1 ]; then
    render_pkgdiff "$pkgdiff"
  else
    printf '_Package scan failed for this image; package diff unavailable._\n\n'
  fi
  if [ "$node_changed" = 0 ]; then
    render_changelogs "$bver" "$aver"
  fi

  return "$node_changed"
}

# Echoes "<images_changed> <node_bumps>" on stdout. Dedups pairs so one image
# pinned via several compose anchors is scanned and reported once.
build_report() {
  local report="$1" removed="$2" added="$3"
  local bref aref nchanged=0 nnode=0
  while IFS=$'\t' read -r bref aref; do
    [ -z "$bref" ] && continue
    if process_pair "$bref" "$aref" >>"$report"; then
      nnode=$((nnode + 1))
    fi
    nchanged=$((nchanged + 1))
  done < <(pair_digests "$removed" "$added" | awk '!seen[$0]++')

  printf '%s %s\n' "$nchanged" "$nnode"
}

assemble_final() {
  local nchanged="$1" nnode="$2" report="$3"
  printf '## Docker image changes\n\n'
  if [ "$nchanged" -le 0 ]; then
    printf '_No Docker image changes detected in this update._\n'
    return
  fi
  if [ "$nnode" -gt 0 ]; then
    printf '%s Docker image(s) changed; %s bumped the Node.js runtime.\n\n' "$nchanged" "$nnode"
  else
    printf '%s Docker image(s) changed; no Node.js runtime change.\n\n' "$nchanged"
  fi
  cat "$report"
}

upsert_pr() {
  local blockfile="$1"
  local have_content="$2"

  if ! command -v gh >/dev/null 2>&1; then
    log "gh not on PATH; skipping PR update"
    return 0
  fi

  local token_env token
  token_env="$(plugin_read GITHUB_TOKEN_ENV "GITHUB_TOKEN")"
  token="${!token_env:-}"
  if [ -z "$token" ]; then
    log "token env ${token_env} is empty; skipping PR update"
    return 0
  fi

  local repo_url slug
  repo_url="${BUILDKITE_PULL_REQUEST_REPO:-${BUILDKITE_REPO:-}}"
  slug="$(repo_slug "$repo_url")"

  local pr="${BUILDKITE_PULL_REQUEST:-}"
  case "$pr" in
    '' | *[!0-9]*)
      # BUILDKITE_PULL_REQUEST is a number only on PR builds; on branch-push it is
      # "false", so fall back to looking up an open PR for the current branch.
      local branch="${BUILDKITE_BRANCH:-}"
      if [ -z "$branch" ]; then
        log "not a pull request and no branch to resolve; skipping PR update"
        return 0
      fi
      pr="$(GH_TOKEN="$token" gh pr list --repo "$slug" --head "$branch" \
            --state open --json number -q '.[0].number' 2>/dev/null)"
      case "$pr" in
        '' | *[!0-9]*)
          log "no open PR for branch ${branch}; skipping PR update"
          return 0
          ;;
      esac
      log "resolved open PR #${pr} for branch ${branch}"
      ;;
  esac

  local cur
  if ! cur="$(GH_TOKEN="$token" gh pr view "$pr" --repo "$slug" --json body -q .body 2>/dev/null)"; then
    log "could not read PR #${pr} body; skipping PR update"
    return 0
  fi
  [ "$cur" = "null" ] && cur=""

  local had_block=0
  grep -qF "$MARKER_START" <<<"$cur" && had_block=1

  # Nothing to say and nothing to clean up -> leave the description untouched.
  if [ "$had_block" -eq 0 ] && [ "$have_content" -le 0 ]; then
    log "no image changes and no existing block; leaving PR description untouched"
    return 0
  fi

  local newbody="${WORKDIR}/newbody.md"
  if [ "$had_block" -eq 1 ]; then
    # Replace the first block in place; drop any duplicate blocks. Preserves
    # the content both above and below the block.
    awk -v start="$MARKER_START" -v end="$MARKER_END" -v bf="$blockfile" '
      function dumpblock() { while ((getline l < bf) > 0) print l; close(bf) }
      function flushbuf(   i) { for (i = 1; i <= n; i++) print buf[i]; n = 0 }
      index($0, start)       { if (!done) { dumpblock(); done = 1 } skip = 1; n = 0; next }
      skip && index($0, end) { skip = 0; n = 0; next }
      skip                   { buf[++n] = $0; next }
      !skip                  { print }
      END                    { if (skip) flushbuf() }
    ' <<<"$cur" >"$newbody"
  elif [ -n "$cur" ]; then
    # First post into a non-empty body: separate it from the block.
    { printf '%s\n\n---\n\n' "$cur"; cat "$blockfile"; } >"$newbody"
  else
    # Empty body: write the block alone, no leading separator.
    cat "$blockfile" >"$newbody"
  fi

  if ! GH_TOKEN="$token" gh pr edit "$pr" --repo "$slug" --body-file "$newbody"; then
    log "could not update PR #${pr}"
    return 0
  fi
  log "updated PR #${pr} description"
}

main() {
  branch_allowed || exit 0

  if is_fork_pr; then
    log "pull request from a fork (source repo != base repo); refusing to scan untrusted images; skipping"
    exit 0
  fi

  local diff_base diff
  diff_base="$(resolve_diff_base)"
  diff="$(git --no-pager diff "${diff_base}...HEAD" || true)"

  local removed added report
  removed="$(mktemp "${WORKDIR}/removed.XXXXXX")"
  added="$(mktemp "${WORKDIR}/added.XXXXXX")"
  extract_refs "$diff" "$removed" "$added"

  report="$(mktemp "${WORKDIR}/report.XXXXXX")"
  local nchanged nnode
  read -r nchanged nnode < <(build_report "$report" "$removed" "$added")

  local final block
  final="$(mktemp "${WORKDIR}/final.XXXXXX")"
  assemble_final "$nchanged" "$nnode" "$report" >"$final"

  block="$(mktemp "${WORKDIR}/block.XXXXXX")"
  {
    printf '%s\n\n' "$MARKER_START"
    cat "$final"
    printf '\n%s\n' "$MARKER_END"
  } >"$block"

  cat "$final"
  upsert_pr "$block" "$nchanged"
}

# Allow BATS tests to source this hook without executing main(). BATS_TEST_DIRNAME
# is set only inside a running bats test and is not exported to child processes, so
# main() still runs both when Buildkite sources the hook and when it is executed.
if [ -z "${BATS_TEST_DIRNAME:-}" ]; then
  main "$@"
fi
